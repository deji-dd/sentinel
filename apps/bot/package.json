{
  "name": "bot",
  "version": "1.0.0",
  "private": true,
  "description": "Sentinel Discord bot",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "NODE_ENV=development tsx watch src/index.ts _app=sentinel-bot",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js _app=sentinel-bot",
    "deploy-commands": "tsx src/deploy-commands.ts",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@sentinel/shared": "workspace:*",
    "@types/express": "^5.0.6",
    "better-sqlite3": "^12.6.2",
    "discord.js": "^14.25.1",
    "dotenv": "^17.2.3",
    "sharp": "^0.35.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@typescript-eslint/eslint-plugin": "^8.53.1",
    "@typescript-eslint/parser": "^8.53.1",
    "eslint": "^9.39.2",
    "globals": "^17.1.0",
    "ts-node": "^10.9.2",
    "tsx": "^4",
    "typescript": "^5"
  },
  "packageManager": "pnpm@10.28.0"
}
