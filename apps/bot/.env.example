# Node.js .env file (.env)
# Create .env in this directory and copy values below
# Variables are loaded via --env-file flag in package.json dev/start scripts

# Discord Bot Credentials (required)
DISCORD_BOT_TOKEN=your_bot_token_here
DISCORD_CLIENT_ID=your_client_id_here

# Local Supabase (for development - get from `pnpm supabase status`)
SUPABASE_URL_LOCAL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY_LOCAL=your_local_service_role_key

# Cloud Supabase (for production)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_cloud_service_role_key

# Encryption & Security (required - must match worker)
ENCRYPTION_KEY=your_32_char_encryption_key_here
API_KEY_HASH_PEPPER=your_random_pepper_string_here

# Deployment
NODE_ENV=development

# Assist edge proxy configuration
# Proxy secret must match Cloudflare Worker secret ASSIST_PROXY_SECRET
ASSIST_PROXY_SECRET=your_proxy_shared_secret

# Optional payload guard for proxied assist event JSON bodies
ASSIST_MAX_PAYLOAD_BYTES=16384

# Install link base URLs used by /assist generate
# Production should point to your Cloudflare worker domain + /install
ASSIST_INSTALL_BASE_URL=https://assist.example.workers.dev/install

# Local override for development mode
ASSIST_INSTALL_BASE_URL_LOCAL=http://127.0.0.1:8787/install
