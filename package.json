{
  "name": "sentinel",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "dev": "pnpm -r dev",
    "build": "pnpm -r build",
    "bot:dev": "pnpm --filter bot dev",
    "bot:build": "pnpm --filter bot build",
    "bot:lint": "pnpm --filter bot lint",
    "worker:dev": "pnpm --filter worker dev",
    "worker:build": "pnpm --filter worker build",
    "worker:lint": "pnpm --filter worker lint",
    "worker:test:speed": "pnpm --filter worker task src/scripts/run-speed-tests.ts",
    "test": "pnpm worker:test:speed",
    "ui:dev": "pnpm --filter ui dev",
    "ui:build": "pnpm --filter ui build",
    "dashboard:dev": "pnpm --filter @sentinel/next-ui dev",
    "dashboard:build": "pnpm --filter @sentinel/next-ui build",
    "dashboard:lint": "pnpm --filter @sentinel/next-ui lint",
    "shared:build": "pnpm --filter shared build",
    "generate:torn-types": "pnpm --filter @sentinel/shared generate-types && pnpm --filter @sentinel/shared build",
    "sqlite:migrate": "pnpm --filter worker migrate:sqlite",
    "sqlite:new-migration": "node scripts/new-sqlite-migration.js",
    "alliances:refresh-snapshot": "node scripts/refresh-faction-alliances-snapshot.js"
  },
  "devDependencies": {
    "openapi-typescript": "^7.10.1"
  }
}
